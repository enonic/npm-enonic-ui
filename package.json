{
  "name": "@enonic/ui",
  "version": "0.50.1",
  "description": "Enonic UI Component Library",
  "author": "Enonic",
  "license": "MIT",
  "homepage": "https://github.com/enonic/npm-enonic-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enonic/npm-enonic-ui.git"
  },
  "bugs": {
    "url": "https://github.com/enonic/npm-enonic-ui/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "keywords": [
    "enonic",
    "ui",
    "components",
    "preact",
    "react",
    "typescript",
    "tailwind"
  ],
  "style": "dist/styles/style.css",
  "type": "module",
  "main": "dist/enonic-ui.cjs",
  "module": "dist/enonic-ui.es.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist/enonic-ui.es.js",
    "dist/enonic-ui.cjs",
    "dist/styles/",
    "dist/types/"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/enonic-ui.es.js",
      "require": "./dist/enonic-ui.cjs"
    },
    "./style.css": "./dist/styles/style.css",
    "./preset.css": "./dist/styles/preset.css",
    "./tokens.css": "./dist/styles/tokens.css",
    "./base.css": "./dist/styles/base.css",
    "./utilities.css": "./dist/styles/utilities.css"
  },
  "scripts": {
    "build": "pnpm clean && pnpm build:ui",
    "build:ui": "pnpm run /^build:ui:.*$/",
    "build:ui:lib": "vp build --config vite.config.ts",
    "build:ui:css": "vp build --config vite.config.css.ts",
    "build:storybook": "storybook build",
    "build:all": "pnpm build && pnpm build:storybook",
    "dev": "storybook dev -p 6006",
    "clean": "rm -rf dist coverage reports storybook-static",
    "check": "vp check && tsgo --build --noEmit",
    "check:fix": "vp check --fix && tsgo --build --noEmit",
    "typecheck": "tsgo --build --noEmit",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "test": "exit 0",
    "test:ci": "exit 0",
    "prepack": "echo 'Packaging...'",
    "prepublishOnly": "pnpm check && pnpm build && pnpm size",
    "release:dry": "pnpm publish --dry-run --no-git-checks",
    "analyze": "pnpm build && open dist/stats.html",
    "size": "size-limit",
    "preview": "pnpm dlx serve . -p 4000",
    "prepare": "vp config"
  },
  "dependencies": {
    "class-variance-authority": "~0.7.1",
    "clsx": "~2.1.1",
    "lucide-react": "^1.16.0",
    "tailwind-merge": "~3.6.0"
  },
  "peerDependencies": {
    "@radix-ui/react-slot": "^1.2.0",
    "focus-trap-react": "^11.0.0",
    "preact": ">=10.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-virtuoso": "^4.0.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependenciesMeta": {
    "focus-trap-react": {
      "optional": true
    },
    "preact": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-virtuoso": {
      "optional": true
    },
    "tw-animate-css": {
      "optional": true
    }
  },
  "devDependencies": {
    "@preact/preset-vite": "~2.10.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@size-limit/preset-small-lib": "~12.1.0",
    "@storybook/addon-a11y": "~10.4.1",
    "@storybook/addon-docs": "~10.4.1",
    "@storybook/addon-themes": "~10.4.1",
    "@storybook/preact-vite": "~10.4.1",
    "@tailwindcss/vite": "~4.3.0",
    "@types/node": "~25.9.1",
    "@types/react": "~19.2.15",
    "@types/react-dom": "~19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260527.1",
    "focus-trap-react": "^12.0.2",
    "lucide-preact": "~1.16.0",
    "react-virtuoso": "^4.18.7",
    "rollup-plugin-visualizer": "~7.0.1",
    "size-limit": "~12.1.0",
    "storybook": "~10.4.1",
    "tailwindcss": "~4.3.0",
    "terser": "~5.48.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "vite": "catalog:",
    "vite-plugin-dts": "~5.0.1",
    "vite-plugin-environment": "~1.1.3",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11.4.0"
  },
  "packageManager": "pnpm@11.4.0",
  "size-limit": [
    {
      "path": "dist/enonic-ui.es.js",
      "limit": "60 KB"
    },
    {
      "path": "dist/enonic-ui.cjs",
      "limit": "60 KB"
    },
    {
      "path": "dist/styles/style.css",
      "limit": "15 KB"
    },
    {
      "path": "dist/styles/preset.css",
      "limit": "2 KB"
    }
  ]
}
