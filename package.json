{
  "name": "@enonic/ui",
  "version": "0.0.1",
  "description": "Enonic UI Component Library",
  "type": "module",
  "main": "dist/enonic-ui.cjs.js",
  "module": "dist/enonic-ui.es.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/enonic-ui.es.js",
      "require": "./dist/enonic-ui.cjs.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "pnpm compile && vite build && storybook build",
    "dev": "storybook dev -p 6006",
    "compile": "tsc -b",
    "vite": "vite build",
    "storybook": "storybook build",
    "clean": "rm -rf dist coverage reports",
    "check": "pnpm lint:fix && pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --no-cache '**/*.{js,jsx,ts,tsx}' --max-warnings 0",
    "lint:fix": "eslint --cache '**/*.{js,jsx,ts,tsx}' --fix",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,json}' --log-level warn",
    "test": "exit 0",
    "test:ci": "exit 0",
    "coverage": "exit 0",
    "analyze": "exit 0",
    "examples": "pnpm dlx serve . -p 4000",
    "preview": "vite preview",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-preact": "^0.525.0",
    "lucide-react": "^0.525.0",
    "tailwind-merge": "^3.3.0"
  },
  "peerDependencies": {
    "@preact/compat": "^18.3.1",
    "preact": ">=10.0.0",
    "react": "^19.1.0"
  },
  "peerDependenciesMeta": {
    "preact": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.0.0",
    "@eslint/js": "^9.28.0",
    "@preact/preset-vite": "^2.10.1",
    "@storybook/addon-a11y": "^9.0.6",
    "@storybook/addon-docs": "^9.0.6",
    "@storybook/addon-links": "^9.0.6",
    "@storybook/addon-themes": "^9.0.6",
    "@storybook/preact-vite": "^9.0.6",
    "@tailwindcss/vite": "^4.1.8",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^22.15.28",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^9.28.0",
    "eslint-import-resolver-typescript": "^4.4.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.5.4",
    "prettier": "^3.5.3",
    "storybook": "^9.0.6",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-environment": "^1.1.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">= 10.11.0",
    "npm": ">=10.8.2"
  },
  "packageManager": "pnpm@10.12.1"
}
