{
  "name": "@enonic/ui",
  "version": "0.5.0",
  "description": "Enonic UI Component Library",
  "author": "Enonic",
  "license": "MIT",
  "homepage": "https://github.com/enonic/npm-enonic-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enonic/npm-enonic-ui.git"
  },
  "bugs": {
    "url": "https://github.com/enonic/npm-enonic-ui/issues"
  },
  "keywords": [
    "enonic",
    "ui",
    "components",
    "preact",
    "react",
    "typescript",
    "tailwind"
  ],
  "type": "module",
  "main": "dist/enonic-ui.cjs",
  "module": "dist/enonic-ui.es.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist/types/",
    "dist/enonic-ui.es.js",
    "dist/enonic-ui.cjs",
    "dist/style.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/enonic-ui.es.js",
      "require": "./dist/enonic-ui.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "pnpm clean && pnpm build:lib",
    "build:lib": "pnpm compile && vite build",
    "build:storybook": "storybook build",
    "build:all": "pnpm build && pnpm build:storybook",
    "dev": "storybook dev -p 6006",
    "compile": "tsc -b",
    "clean": "rm -rf dist coverage reports storybook-static",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --no-cache '**/*.{js,jsx,ts,tsx}' --max-warnings 0",
    "lint:fix": "eslint --cache '**/*.{js,jsx,ts,tsx}' --fix",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,json,md,yml,yaml}' --log-level warn",
    "format:check": "prettier --check '**/*.{js,jsx,ts,tsx,json,md,yml,yaml}' --log-level warn",
    "test": "exit 0",
    "test:ci": "exit 0",
    "prepack": "echo 'Packaging...'",
    "prepublishOnly": "pnpm check && pnpm build && pnpm size",
    "release": "pnpm publish --access public --no-git-checks",
    "release:dry": "pnpm publish --dry-run --access public --no-git-checks",
    "analyze": "pnpm build && open dist/stats.html",
    "size": "size-limit",
    "preview": "pnpm dlx serve . -p 4000",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-slot": "~1.2.3",
    "class-variance-authority": "~0.7.1",
    "clsx": "~2.1.1",
    "tailwind-merge": "~3.3.1"
  },
  "peerDependencies": {
    "@preact/compat": ">=17.0.0 || >=18.0.0",
    "preact": ">=10.0.0",
    "react": ">=18.0.0 || >=19.0.0",
    "react-dom": ">=18.0.0 || >=19.0.0"
  },
  "peerDependenciesMeta": {
    "@preact/compat": {
      "optional": true
    },
    "lucide-preact": {
      "optional": true
    },
    "preact": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "~4.1.1",
    "@eslint/js": "~9.34.0",
    "@preact/preset-vite": "~2.10.2",
    "@size-limit/file": "~11.2.0",
    "@size-limit/preset-small-lib": "~11.2.0",
    "@storybook/addon-a11y": "~9.1.3",
    "@storybook/addon-docs": "~9.1.3",
    "@storybook/addon-links": "~9.1.3",
    "@storybook/addon-themes": "~9.1.3",
    "@storybook/preact-vite": "~9.1.3",
    "@tailwindcss/vite": "~4.1.12",
    "@trivago/prettier-plugin-sort-imports": "~5.2.2",
    "@types/node": "~24.3.0",
    "@typescript-eslint/eslint-plugin": "~8.41.0",
    "@typescript-eslint/parser": "~8.41.0",
    "eslint": "~9.34.0",
    "eslint-import-resolver-typescript": "~4.4.4",
    "eslint-plugin-import": "~2.32.0",
    "eslint-plugin-jsx-a11y": "~6.10.2",
    "eslint-plugin-react": "~7.37.5",
    "eslint-plugin-react-hooks": "~5.2.0",
    "husky": "~9.1.7",
    "lint-staged": "~16.1.5",
    "lucide-preact": "~0.541.0",
    "lucide-react": "~0.541.0",
    "postcss": "~8.5.6",
    "prettier": "~3.6.2",
    "rollup-plugin-visualizer": "~6.0.3",
    "size-limit": "~11.2.0",
    "storybook": "~9.1.3",
    "tailwindcss": "~4.1.12",
    "terser": "~5.43.1",
    "tw-animate-css": "~1.3.7",
    "typescript": "~5.9.2",
    "typescript-eslint": "~8.41.0",
    "vite": "~7.1.3",
    "vite-plugin-dts": "~4.5.4",
    "vite-plugin-environment": "~1.1.3"
  },
  "pnpm": {
    "overrides": {
      "vite-prerender-plugin": "^0.5.11"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=22.17.1",
    "pnpm": ">= 10.11.0",
    "npm": ">=9.15.9"
  },
  "packageManager": "pnpm@10.15.0",
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "size-limit": [
    {
      "path": "dist/enonic-ui.es.js",
      "limit": "35 KB"
    },
    {
      "path": "dist/enonic-ui.cjs",
      "limit": "35 KB"
    },
    {
      "path": "dist/style.css",
      "limit": "15 KB"
    }
  ]
}
